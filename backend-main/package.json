{
  "name": "auction-backend-main",
  "version": "1.0.0",
  "description": "Real-time game engine backend using Express and Socket.io",
  "main": "src/index.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env src/index.js",
    "dev": "node --env-file-if-exists=.env src/index.js",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "express",
    "socket.io",
    "websocket",
    "game-engine"
  ],
  "license": "MIT",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "pino": "^10.3.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.1.1",
    "vitest": "^3.1.1"
  }
}
