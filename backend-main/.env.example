# Local server bind/port
PORT=3000

# Required
ADMIN_SECRET=replace-with-a-strong-secret

# Required in production. On Render this is injected from the Key Value service.
REDIS_URL=

# Allowed browser origins
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# Game config
ROUND_DURATION_MS=60000
TOTAL_ROUNDS=6

# Optional tuning
REDIS_KEY_PREFIX=auction-game
SCHEDULER_INTERVAL_MS=250
SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=20000

# Local-only escape hatch when you want to run without Redis.
# Do not enable this in production.
# ALLOW_IN_MEMORY_STORE=true
